# syntax = docker/dockerfile:1.7
# Dev image: runs `next dev` with source mounted from the host for hot reload.

FROM node:22-alpine
WORKDIR /app

# Install dependencies (incl. devDependencies) up front so node_modules
# is baked into the image and survives the anonymous-volume mount below.
COPY package.json package-lock.json ./
RUN npm ci --frozen-lockfile

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

CMD ["npm", "run", "dev"]
